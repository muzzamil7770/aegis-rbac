# Normalize all text files to use LF on checkout
* text=auto eol=lf

# Explicitly declare text files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.env* text eol=lf

# Binary files - do not modify
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.webp binary
*.sqlite binary
